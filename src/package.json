{
  "name": "skypulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:seed": "node dist/seed_db.js",
    "seed": "tsx seed_db.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "conformance": "tsx tests/conformance/runner.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.4.1",
    "helmet": "8.1.0",
    "lru-cache": "11.3.5",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/supertest": "7.2.0",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
